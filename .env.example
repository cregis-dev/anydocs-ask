# ============================================================================
# anydocs-ask environment template
# ============================================================================
# Copy this file to `.env` (in the project root you pass to `anydocs-ask serve`,
# or the cwd you launch from) and fill in the values for your environment.
#
# `.env` is loaded automatically by the CLI before each command runs. Existing
# shell exports take precedence over .env; .env values fill in the gaps.
# ============================================================================


# ----------------------------------------------------------------------------
# LLM credentials — Anthropic-compatible gateway
# ----------------------------------------------------------------------------
# Pick exactly ONE auth path:
#
#   (A) Native Anthropic API
#       ANTHROPIC_API_KEY=sk-ant-...
#       (leave ANTHROPIC_AUTH_TOKEN and ANTHROPIC_BASE_URL unset to use
#       https://api.anthropic.com)
#
#   (B) Internal company gateway speaking the Anthropic /v1/messages protocol
#       (Bearer auth + custom base URL)
#       ANTHROPIC_AUTH_TOKEN=<your-bearer-token>
#       ANTHROPIC_BASE_URL=https://gateway.your-company.example.com
# ----------------------------------------------------------------------------

# Bearer token sent as `Authorization: Bearer <token>` to the gateway.
# Required when using an internal Anthropic-compatible gateway.
ANTHROPIC_AUTH_TOKEN=

# Base URL of the gateway. Should NOT include `/v1/messages` — the SDK
# appends that itself. e.g. https://llm-gateway.internal.example.com
ANTHROPIC_BASE_URL=

# Native Anthropic API key (sent as `x-api-key`). Only set this if you're
# talking to api.anthropic.com directly. Leave blank when using a gateway
# with ANTHROPIC_AUTH_TOKEN.
ANTHROPIC_API_KEY=


# ----------------------------------------------------------------------------
# Model id (env beats anydocs.ask.json)
# ----------------------------------------------------------------------------
# When set, this overrides `llm.model` in anydocs.ask.json. Use this for
# gateway-specific model aliases (e.g. `company-claude-sonnet`,
# `prod-claude-37-sonnet`) that you don't want to commit into the project's
# config file. Leave blank to fall back to anydocs.ask.json's value (which
# defaults to `claude-sonnet-4-6`).
# ----------------------------------------------------------------------------

ANTHROPIC_MODEL=


# ----------------------------------------------------------------------------
# Optional: MCP knowledge-base interface (RFC 0007)
# ----------------------------------------------------------------------------
# Bearer token required on POST /mcp when `mcp.enabled` is true in
# anydocs.ask.json. When set, agents must send `Authorization: Bearer <token>`;
# a mismatch returns 401. Leave blank to run the endpoint open — only safe for
# loopback / trusted-network binds, where the DNS-rebinding Host guard applies.
# Secrets stay in the env, never in anydocs.ask.json.
# ANYDOCS_MCP_TOKEN=


# ----------------------------------------------------------------------------
# Optional: Node runtime
# ----------------------------------------------------------------------------
# Switches CORS to production mode (denies all origins not in
# server.cors.allowedOrigins). Leave unset for local dev.
# NODE_ENV=production


# ----------------------------------------------------------------------------
# Optional: transformers.js (bge-m3) model cache directory
# ----------------------------------------------------------------------------
# Default: ~/.cache/huggingface/anydocs-ask/transformers/  (stable across
# worktrees / pnpm install). Set this only to point a shared CI cache or a
# non-default disk. Overrides anydocs.ask.json `embedding.cacheDir`.
# ANYDOCS_TRANSFORMERS_CACHE=/var/cache/anydocs-ask/transformers
